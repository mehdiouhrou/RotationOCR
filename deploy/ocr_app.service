[Unit]
Description=LocaGed OCR Flask App
After=network.target

[Service]
Type=simple
User=www-data
Group=www-data
WorkingDirectory=/opt/ocr_app
EnvironmentFile=/opt/ocr_app/.env
Environment=HOME=/opt/ocr_app/.runtime
# Use venv gunicorn (requirements live in .venv, not system Python).
ExecStart=/opt/ocr_app/.venv/bin/gunicorn -w 2 -b 127.0.0.1:5050 app:app
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
